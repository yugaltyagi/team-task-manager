# Local PostgreSQL — adjust user, password, host, port, and database name to match your install.
# Example after creating DB:  CREATE DATABASE teamtasks;
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/teamtasks?schema=public"

# Railway: use the Postgres plugin variable. Production start runs: prisma migrate deploy
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN="http://localhost:5173"
